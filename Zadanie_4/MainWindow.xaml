<Window x:Class="Z4_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kalkulator – Zadanie 4"
        Width="320" Height="530"
        ResizeMode="CanMinimize"
        Background="#1e1e2e">

    <Window.Resources>

        <!-- ── Bazowy ControlTemplate dla wszystkich przycisków ── -->
        <ControlTemplate x:Key="BtnTemplate" TargetType="Button">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="5" Margin="{TemplateBinding Margin}">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ── Styl bazowy ── -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="#cdd6f4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin"          Value="3"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template"        Value="{StaticResource BtnTemplate}"/>
        </Style>

        <!-- ── Styl: zwykłe cyfry / operacje ── -->
        <Style x:Key="BtnNormal" TargetType="Button"
               BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#313244"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
        </Style>

        <!-- ── Styl: operatory binarne ── -->
        <Style x:Key="BtnOp" TargetType="Button"
               BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#1e3a5f"/>
            <Setter Property="BorderBrush" Value="#89b4fa"/>
            <Setter Property="Foreground"  Value="#89b4fa"/>
        </Style>

        <!-- ── Styl: operacje z % ── -->
        <Style x:Key="BtnPercent" TargetType="Button"
               BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#1e3b2f"/>
            <Setter Property="BorderBrush" Value="#a6e3a1"/>
            <Setter Property="Foreground"  Value="#a6e3a1"/>
        </Style>

        <!-- ── Styl: funkcje jednoargumentowe ── -->
        <Style x:Key="BtnUnary" TargetType="Button"
               BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#2a2a3e"/>
            <Setter Property="BorderBrush" Value="#cba6f7"/>
            <Setter Property="Foreground"  Value="#cba6f7"/>
        </Style>

        <!-- ── Styl: równa się ── -->
        <Style x:Key="BtnEquals" TargetType="Button"
               BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#89b4fa"/>
            <Setter Property="BorderBrush" Value="#b4befe"/>
            <Setter Property="Foreground"  Value="#1e1e2e"/>
            <Setter Property="FontSize"    Value="18"/>
        </Style>

        <!-- ── Styl: reset (C) ── -->
        <Style x:Key="BtnClear" TargetType="Button"
               BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#3b1f2b"/>
            <Setter Property="BorderBrush" Value="#f38ba8"/>
            <Setter Property="Foreground"  Value="#f38ba8"/>
        </Style>

    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <!-- etykieta operacji -->
            <RowDefinition Height="24"/>
            <!-- wyświetlacz -->
            <RowDefinition Height="64"/>
            <!-- odstęp -->
            <RowDefinition Height="6"/>
            <!-- 7 wierszy przycisków -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Etykieta operacji ── -->
        <TextBlock x:Name="OpLabel"
                   Grid.Row="0"
                   Text="{Binding OpDisplay}"
                   Foreground="#6c7086" FontSize="12"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Margin="0,0,4,0"/>

        <!-- ── Wyświetlacz ── -->
        <Border Grid.Row="1"
                Background="#181825" BorderBrush="#313244"
                BorderThickness="2" CornerRadius="6">
            <TextBlock x:Name="Display"
                       Text="{Binding Display}"
                       Foreground="#cdd6f4"
                       FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- ════════════════════════════════════════════════
             SIATKA PRZYCISKÓW (wiersze 3–9)
             ════════════════════════════════════════════════ -->

        <!-- Wiersz 0: C  ±  ⌫  x^y -->
        <UniformGrid Grid.Row="3" Columns="4">
            <Button Content="C"    Style="{StaticResource BtnClear}"   Click="C_Click"/>
            <Button Content="±"    Style="{StaticResource BtnNormal}"  Click="Sign_Click"/>
            <Button Content="⌫"    Style="{StaticResource BtnNormal}"  Click="Back_Click"/>
            <Button Content="x^y" Style="{StaticResource BtnOp}"      Click="Op_Click" Tag="x^y"/>
        </UniformGrid>

        <!-- Wiersz 1: √  x²  1/x  ÷ -->
        <UniformGrid Grid.Row="4" Columns="4">
            <Button Content="√"   Style="{StaticResource BtnUnary}"  Click="Unary_Click" Tag="√"/>
            <Button Content="x²"  Style="{StaticResource BtnUnary}"  Click="Unary_Click" Tag="x²"/>
            <Button Content="1/x" Style="{StaticResource BtnUnary}"  Click="Unary_Click" Tag="1/x"/>
            <Button Content="÷"   Style="{StaticResource BtnOp}"     Click="Op_Click"    Tag="÷"/>
        </UniformGrid>

        <!-- Wiersz 2: %+  %-  %×  %÷ -->
        <UniformGrid Grid.Row="5" Columns="4">
            <Button Content="%+"  Style="{StaticResource BtnPercent}" Click="Op_Click" Tag="%+"/>
            <Button Content="%-"  Style="{StaticResource BtnPercent}" Click="Op_Click" Tag="%-"/>
            <Button Content="%×"  Style="{StaticResource BtnPercent}" Click="Op_Click" Tag="%×"/>
            <Button Content="%÷"  Style="{StaticResource BtnPercent}" Click="Op_Click" Tag="%÷"/>
        </UniformGrid>

        <!-- Wiersz 3: 7  8  9  × -->
        <UniformGrid Grid.Row="6" Columns="4">
            <Button Content="7" Style="{StaticResource BtnNormal}" Click="Digit_Click"/>
            <Button Content="8" Style="{StaticResource BtnNormal}" Click="Digit_Click"/>
            <Button Content="9" Style="{StaticResource BtnNormal}" Click="Digit_Click"/>
            <Button Content="×" Style="{StaticResource BtnOp}"    Click="Op_Click" Tag="×"/>
        </UniformGrid>

        <!-- Wiersz 4: 4  5  6  - -->
        <UniformGrid Grid.Row="7" Columns="4">
            <Button Content="4" Style="{StaticResource BtnNormal}" Click="Digit_Click"/>
            <Button Content="5" Style="{StaticResource BtnNormal}" Click="Digit_Click"/>
            <Button Content="6" Style="{StaticResource BtnNormal}" Click="Digit_Click"/>
            <Button Content="−" Style="{StaticResource BtnOp}"    Click="Op_Click" Tag="-"/>
        </UniformGrid>

        <!-- Wiersz 5: 1  2  3  + -->
        <UniformGrid Grid.Row="8" Columns="4">
            <Button Content="1" Style="{StaticResource BtnNormal}" Click="Digit_Click"/>
            <Button Content="2" Style="{StaticResource BtnNormal}" Click="Digit_Click"/>
            <Button Content="3" Style="{StaticResource BtnNormal}" Click="Digit_Click"/>
            <Button Content="+" Style="{StaticResource BtnOp}"    Click="Op_Click" Tag="+"/>
        </UniformGrid>

        <!-- Wiersz 6: 0 (colspan 2)  .  = -->
        <Grid Grid.Row="9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Grid.ColumnSpan="2"
                    Content="0"
                    Style="{StaticResource BtnNormal}"
                    Click="Digit_Click"/>
            <Button Grid.Column="2"
                    Content="."
                    Style="{StaticResource BtnNormal}"
                    Click="Dot_Click"/>
            <Button Grid.Column="3"
                    Content="="
                    Style="{StaticResource BtnEquals}"
                    Click="Equals_Click"/>
        </Grid>

    </Grid>
</Window>
