<Window x:Class="Z1_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zadanie 1 – Panele z przewijaniem"
        Width="900" Height="620"
        MinWidth="500" MinHeight="400">

    <!--
        Główny układ: Grid z 3 wierszami
          Row 0 – górna belka (poziomy ScrollViewer)
          Row 1 – separator (Gap)
          Row 2 – dolna część: lewy panel + separator + główny obszar
    -->
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <!-- górna belka – stała wysokość -->
            <RowDefinition Height="80"/>
            <!-- przerwa 8px -->
            <RowDefinition Height="8"/>
            <!-- reszta okna -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════
             ROW 0 – Górna belka: poziomo przewijana
             ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                BorderBrush="#313244" BorderThickness="2"
                CornerRadius="6" Background="#1e1e2e">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal"
                            Margin="8,0" VerticalAlignment="Center">

                    <!-- 12 kolorowych boxów -->
                    <Border Width="110" Height="52" Margin="0,0,8,0" CornerRadius="4"
                            Background="#e74c3c" BorderBrush="#c0392b" BorderThickness="2"/>
                    <Border Width="110" Height="52" Margin="0,0,8,0" CornerRadius="4"
                            Background="#e67e22" BorderBrush="#d35400" BorderThickness="2"/>
                    <Border Width="110" Height="52" Margin="0,0,8,0" CornerRadius="4"
                            Background="#f1c40f" BorderBrush="#f39c12" BorderThickness="2"/>
                    <Border Width="110" Height="52" Margin="0,0,8,0" CornerRadius="4"
                            Background="#2ecc71" BorderBrush="#27ae60" BorderThickness="2"/>
                    <Border Width="110" Height="52" Margin="0,0,8,0" CornerRadius="4"
                            Background="#1abc9c" BorderBrush="#16a085" BorderThickness="2"/>
                    <Border Width="110" Height="52" Margin="0,0,8,0" CornerRadius="4"
                            Background="#3498db" BorderBrush="#2980b9" BorderThickness="2"/>
                    <Border Width="110" Height="52" Margin="0,0,8,0" CornerRadius="4"
                            Background="#9b59b6" BorderBrush="#8e44ad" BorderThickness="2"/>
                    <Border Width="110" Height="52" Margin="0,0,8,0" CornerRadius="4"
                            Background="#e91e63" BorderBrush="#c2185b" BorderThickness="2"/>
                    <Border Width="110" Height="52" Margin="0,0,8,0" CornerRadius="4"
                            Background="#00bcd4" BorderBrush="#0097a7" BorderThickness="2"/>
                    <Border Width="110" Height="52" Margin="0,0,8,0" CornerRadius="4"
                            Background="#8bc34a" BorderBrush="#689f38" BorderThickness="2"/>
                    <Border Width="110" Height="52" Margin="0,0,8,0" CornerRadius="4"
                            Background="#ff5722" BorderBrush="#e64a19" BorderThickness="2"/>
                    <Border Width="110" Height="52" Margin="0,0,0,0" CornerRadius="4"
                            Background="#607d8b" BorderBrush="#455a64" BorderThickness="2"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             ROW 2 – dolna część: lewy panel + główny obszar
             ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <!-- lewy panel – stała szerokość -->
                <ColumnDefinition Width="155"/>
                <!-- przerwa 8px -->
                <ColumnDefinition Width="8"/>
                <!-- główny obszar -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Lewy panel: pionowo przewijany ── -->
            <Border Grid.Column="0"
                    BorderBrush="#313244" BorderThickness="2"
                    CornerRadius="6" Background="#1e1e2e">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Vertical"
                                Margin="8" HorizontalAlignment="Stretch">

                        <!-- 12 kolorowych boxów pionowo -->
                        <Border Height="55" Margin="0,0,0,8" CornerRadius="4"
                                Background="#c0392b" BorderBrush="#96281b" BorderThickness="2"/>
                        <Border Height="55" Margin="0,0,0,8" CornerRadius="4"
                                Background="#d35400" BorderBrush="#a04000" BorderThickness="2"/>
                        <Border Height="55" Margin="0,0,0,8" CornerRadius="4"
                                Background="#f39c12" BorderBrush="#b7770d" BorderThickness="2"/>
                        <Border Height="55" Margin="0,0,0,8" CornerRadius="4"
                                Background="#27ae60" BorderBrush="#1e8449" BorderThickness="2"/>
                        <Border Height="55" Margin="0,0,0,8" CornerRadius="4"
                                Background="#16a085" BorderBrush="#0e6655" BorderThickness="2"/>
                        <Border Height="55" Margin="0,0,0,8" CornerRadius="4"
                                Background="#2980b9" BorderBrush="#1a5276" BorderThickness="2"/>
                        <Border Height="55" Margin="0,0,0,8" CornerRadius="4"
                                Background="#8e44ad" BorderBrush="#6c3483" BorderThickness="2"/>
                        <Border Height="55" Margin="0,0,0,8" CornerRadius="4"
                                Background="#c2185b" BorderBrush="#880e4f" BorderThickness="2"/>
                        <Border Height="55" Margin="0,0,0,8" CornerRadius="4"
                                Background="#0097a7" BorderBrush="#006064" BorderThickness="2"/>
                        <Border Height="55" Margin="0,0,0,8" CornerRadius="4"
                                Background="#689f38" BorderBrush="#33691e" BorderThickness="2"/>
                        <Border Height="55" Margin="0,0,0,8" CornerRadius="4"
                                Background="#e64a19" BorderBrush="#bf360c" BorderThickness="2"/>
                        <Border Height="55" Margin="0,0,0,0" CornerRadius="4"
                                Background="#455a64" BorderBrush="#263238" BorderThickness="2"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── Główny obszar: pusty ScrollViewer ── -->
            <Border Grid.Column="2"
                    BorderBrush="#313244" BorderThickness="2"
                    CornerRadius="6" Background="#181825">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <!-- pusta przestrzeń – tu można wstawiać zawartość -->
                    <Grid/>
                </ScrollViewer>
            </Border>

        </Grid>
    </Grid>
</Window>
