<Window x:Class="Z2_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zadanie 2 – Siatka i Style Przycisków"
        Width="860" Height="580"
        MinWidth="600" MinHeight="420"
        Background="#1e1e2e">

    <Window.Resources>

        <!-- ═══════════════════════════════════════════════════════════════
             B – WZORZEC (ControlTemplate) przycisków
             Niebieski, obramowanie 5px, margines 3px
             Hover  → jasne tło + tekst w kolorze bordera
             Pressed→ ciemniejszy odcień
             ═══════════════════════════════════════════════════════════════ -->
        <Style x:Key="ButtonTemplate" TargetType="Button">
            <Setter Property="Background"   Value="#4a90d9"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderBrush"  Value="#1a5fa8"/>
            <Setter Property="BorderThickness" Value="5"/>
            <Setter Property="Margin"       Value="3"/>
            <Setter Property="Padding"      Value="10,6"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter x:Name="content"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"   Property="Background"   Value="#d4e8ff"/>
                                <Setter TargetName="border"   Property="BorderBrush"  Value="#1a5fa8"/>
                                <!-- kolor tekstu zgodny z borderem -->
                                <Setter TargetName="content"  Property="TextElement.Foreground" Value="#1a5fa8"/>
                            </Trigger>
                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"   Property="Background"   Value="#a0c8f0"/>
                                <Setter TargetName="border"   Property="BorderBrush"  Value="#1a5fa8"/>
                                <Setter TargetName="content"  Property="TextElement.Foreground" Value="#1a5fa8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════
             B☆ – STYL ALTERNATYWNY identyfikowany kluczem "ButtonAlt"
             Pomarańczowy – pojawia się w każdej belce
             Dziedziczy Template z ButtonTemplate
             ═══════════════════════════════════════════════════════════════ -->
        <Style x:Key="ButtonAlt" TargetType="Button"
               BasedOn="{StaticResource ButtonTemplate}">
            <Setter Property="Background"  Value="#e67e22"/>
            <Setter Property="BorderBrush" Value="#a04000"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter x:Name="content"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"  Property="Background"  Value="#fde8d0"/>
                                <Setter TargetName="border"  Property="BorderBrush" Value="#a04000"/>
                                <Setter TargetName="content" Property="TextElement.Foreground" Value="#a04000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"  Property="Background"  Value="#f0b97a"/>
                                <Setter TargetName="border"  Property="BorderBrush" Value="#a04000"/>
                                <Setter TargetName="content" Property="TextElement.Foreground" Value="#a04000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════
         GŁÓWNA SIATKA
         Row 0 – górna belka
         Row 1 – przerwa
         Row 2 – sub-siatka (lewa belka + przestrzeń + dolna belka)
         ═══════════════════════════════════════════════════════════════════ -->
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── GÓRNA BELKA ── -->
        <Border Grid.Row="0"
                Background="#2a2a3e" BorderBrush="#313244"
                BorderThickness="2" CornerRadius="6" Padding="4">
            <StackPanel Orientation="Horizontal">
                <!-- B – przyciski z wzorcem -->
                <Button Content="Top B 1" Style="{StaticResource ButtonTemplate}"/>
                <Button Content="Top B 2" Style="{StaticResource ButtonTemplate}"/>
                <Button Content="Top B 3" Style="{StaticResource ButtonTemplate}"/>
                <!-- B☆ – styl alternatywny przez klucz -->
                <Button Content="Top B☆"  Style="{StaticResource ButtonAlt}"/>
            </StackPanel>
        </Border>

        <!-- ── SUB-SIATKA ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── LEWA BELKA (sub-siatka, col 0, rows 0+2) ──
                 B* – styl zdefiniowany w zasobach sub-siatki (zielony)
                 Każdy przycisk w tej belce dostaje styl z Resources tej Border -->
            <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                    Background="#1e3b2f" BorderBrush="#27ae60"
                    BorderThickness="2" CornerRadius="6">
                <Border.Resources>
                    <!-- B* – styl sub-siatki dziedziczący template, zielone tło -->
                    <Style x:Key="ButtonSub" TargetType="Button"
                           BasedOn="{StaticResource ButtonTemplate}">
                        <Setter Property="Background"  Value="#27ae60"/>
                        <Setter Property="BorderBrush" Value="#1a7a42"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Margin="{TemplateBinding Margin}">
                                        <ContentPresenter x:Name="content"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Margin="{TemplateBinding Padding}"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border"  Property="Background"  Value="#d5f5e3"/>
                                            <Setter TargetName="border"  Property="BorderBrush" Value="#1a7a42"/>
                                            <Setter TargetName="content" Property="TextElement.Foreground" Value="#1a7a42"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border"  Property="Background"  Value="#a9dfbf"/>
                                            <Setter TargetName="border"  Property="BorderBrush" Value="#1a7a42"/>
                                            <Setter TargetName="content" Property="TextElement.Foreground" Value="#1a7a42"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Border.Resources>

                <StackPanel Orientation="Vertical" Margin="8" VerticalAlignment="Top">
                    <Button Content="Left B*1" Style="{StaticResource ButtonSub}"/>
                    <Button Content="Left B*2" Style="{StaticResource ButtonSub}"/>
                    <Button Content="Left B*3" Style="{StaticResource ButtonSub}"/>
                    <!-- B☆ w lewej belce -->
                    <Button Content="Left B☆"  Style="{StaticResource ButtonAlt}"/>
                </StackPanel>
            </Border>

            <!-- ── PRZESTRZEŃ NA ZAWARTOŚĆ (col 2, row 0) ── -->
            <Border Grid.Column="2" Grid.Row="0"
                    Background="#181825" BorderBrush="#313244"
                    BorderThickness="2" CornerRadius="6">
                <!-- pusta komórka siatki – miejsce na zawartość -->
            </Border>

            <!-- ── DOLNA BELKA (col 2, row 2) ── -->
            <Border Grid.Column="2" Grid.Row="2"
                    Background="#2a2a3e" BorderBrush="#313244"
                    BorderThickness="2" CornerRadius="6" Padding="4">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Bot B*1" Style="{StaticResource ButtonTemplate}"/>
                    <Button Content="Bot B*2" Style="{StaticResource ButtonTemplate}"/>
                    <!-- B☆ w dolnej belce -->
                    <Button Content="Bot B☆"  Style="{StaticResource ButtonAlt}"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Window>
